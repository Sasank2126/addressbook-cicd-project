pipeline {
    agent any
    
    options {
        timeout(time: 10, unit: 'MINUTES')
        buildDiscarder(logRotator(numToKeepStr: '5'))
    }

    stages {
        stage("clone from github") {
            steps {
                git 'https://github.com/VengalaRao-118/addressbook-cicd-project/'
                echo 'clone done'
            }
        }

        stage("compile the project") {
            steps {
                sh 'mvn compile'
            }
        }

        stage("run the test cases") {
            steps {
                sh 'mvn package'
            }
        }

        stage("Approval") {
            steps {
                input "Approve to deploy"
            }
        }

        stage("Deploy to Tomcat") {
            steps {
                sh "sudo cp /var/lib/jenkins/workspace/test/target/addressbook.war /home/devops/cicdakshat/apache-tomcat-9.0.118/webapps"
            }
        }
    }

    post {
        success {
            archiveArtifacts artifacts: 'target/*.war'
        }
    }
}

